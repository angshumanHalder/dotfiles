// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "title_bar": {
    "show_onboarding_banner": false,
    "show_user_menu": false,
    "show_user_picture": false,
    "show_project_items": false,
    "show_sign_in": false,
  },

  "tab_bar": {
    "show": false,
  },

  "toolbar": {
    "quick_actions": false,
  },

  "project_panel": {
    "dock": "left",
    "default_width": 250,
    "auto_fold_dirs": false,
    "scrollbar": {
      "show": "never",
    },
  },

  "outline_panel": {
    "dock": "left",
    "default_width": 300,
  },

  "file_finder": {
    "modal_max_width": "large",
  },

  "scrollbar": {
    "show": "never",
  },

  "gutter": {
    "min_line_number_digits": 0,
  },

  "relative_line_numbers": "enabled",

  "ui_font_family": "JetBrains Mono",
  "ui_font_weight": 700.0,
  "ui_font_size": 14.0,
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_weight": 700.0,
  "buffer_font_size": 12.0,
  "agent_buffer_font_size": 14.0,
  "agent_ui_font_size": 14.0,

  "theme": "Kanagawa Dragon",
  "theme_overrides": {
    "Kanagawa Dragon": {
      "border.variant": "#12120f",
      "border": "#12120f",
      "title_bar.background": "#12120f",
      "panel.background": "#12120f",
      "panel.focused_border": "#2D4F67",
      "element.selected": "#2D4F67",
      "element.hover": "#223249",
      "element.active": "#1F384C",
    },
  },

  "vim_mode": true,
  "cursor_blink": false,
  "seed_search_query_from_cursor": "selection",
  "show_whitespaces": "none",

  "cli_default_open_behavior": "existing_window",
  "lsp_document_colors": "inlay",

  "inlay_hints": {
    "show_other_hints": false,
    "show_type_hints": false,
    "show_parameter_hints": false,
    "enabled": true,
  },

  "terminal": {
    "shell": {
      "program": "/bin/zsh",
    },
    "font_family": "JetBrainsMono Nerd Font",
    "font_weight": 700.0,
    "font_size": 12.0,
  },
  "icon_theme": {
    "mode": "dark",
    "light": "JetBrains New UI Icons (Dark)",
    "dark": "JetBrains New UI Icons (Dark)",
  },

  "base_keymap": "VSCode",

  "auto_update": false,

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  "collaboration_panel": {
    "dock": "left",
  },

  "agent": {
    "dock": "right",
    "default_width": 250,
    "favorite_models": [],
    "model_parameters": [],
  },

  "git_panel": {
    "dock": "left",
  },

  "extend_comment_on_newline": false,
}
